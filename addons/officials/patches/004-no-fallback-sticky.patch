From b456577118990d9ec4706269ed2aaeee746945b2 Mon Sep 17 00:00:00 2001
From: bigbrother666sh <wukong@DESKTOP-K31C522.localdomain>
Date: Fri, 17 Apr 2026 09:38:09 +0800
Subject: [PATCH] fix(session): also clear runtimeProvider/runtimeModel when
 skipping auto-fallback sticky

---
 src/gateway/session-utils.ts | 20 +++++++++++++++-----
 1 file changed, 15 insertions(+), 5 deletions(-)

diff --git a/src/gateway/session-utils.ts b/src/gateway/session-utils.ts
index cd385d6341..87aceac8b4 100644
--- a/src/gateway/session-utils.ts
+++ b/src/gateway/session-utils.ts
@@ -960,7 +960,10 @@ export function resolveSessionModelRef(
   cfg: OpenClawConfig,
   entry?:
     | SessionEntry
-    | Pick<SessionEntry, "model" | "modelProvider" | "modelOverride" | "providerOverride">,
+    | Pick<
+        SessionEntry,
+        "model" | "modelProvider" | "modelOverride" | "providerOverride" | "modelOverrideSource"
+      >,
   agentId?: string,
 ): { provider: string; model: string } {
   const resolved = agentId
@@ -971,15 +974,22 @@ export function resolveSessionModelRef(
         defaultModel: DEFAULT_MODEL,
       });
 
+  // When OPENCLAW_NO_FALLBACK_STICKY=1, auto-fallback overrides are ignored so
+  // each new turn retries the configured default model instead of the last
+  // fallback. This avoids cost drift when a provider is temporarily degraded.
+  const skipAutoFallback =
+    process.env.OPENCLAW_NO_FALLBACK_STICKY === "1" && entry?.modelOverrideSource === "auto";
   const normalizedOverride = normalizeStoredOverrideModel({
-    providerOverride: entry?.providerOverride,
-    modelOverride: entry?.modelOverride,
+    providerOverride: skipAutoFallback ? undefined : entry?.providerOverride,
+    modelOverride: skipAutoFallback ? undefined : entry?.modelOverride,
   });
 
   const persisted = resolvePersistedSelectedModelRef({
     defaultProvider: resolved.provider || DEFAULT_PROVIDER,
-    runtimeProvider: entry?.modelProvider,
-    runtimeModel: entry?.model,
+    // Also clear the runtime model/provider fields when skipping auto-fallback,
+    // as they hold the same fallback values and take priority over overrides.
+    runtimeProvider: skipAutoFallback ? undefined : entry?.modelProvider,
+    runtimeModel: skipAutoFallback ? undefined : entry?.model,
     overrideProvider: normalizedOverride.providerOverride,
     overrideModel: normalizedOverride.modelOverride,
   });
-- 
