+    expect(browserActionsMocks.browserAct).not.toHaveBeenCalled();
+  });
+
+  it("rejects fill without fields before calling browserAct", async () => {
+    const tool = createBrowserTool();
+    await expect(
+      tool.execute?.("call-1", {
+        action: "act",
+        request: { kind: "fill" },
+      }),
+    ).rejects.toThrow(/requires fields/i);
+    expect(browserActionsMocks.browserAct).not.toHaveBeenCalled();
+  });
+
+  it("rejects fill with empty fields array before calling browserAct", async () => {
+    const tool = createBrowserTool();
