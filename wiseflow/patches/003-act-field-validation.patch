+describe("browser tool act field validation", () => {
+  registerBrowserToolAfterEachReset();
+
+  it("rejects click without ref before calling browserAct", async () => {
+    const tool = createBrowserTool();
+    await expect(
+      tool.execute?.("call-1", {
+        action: "act",
+        request: { kind: "click", targetId: "t1" },
+      }),
+    ).rejects.toThrow(/requires ref.*action=snapshot/i);
+    expect(browserActionsMocks.browserAct).not.toHaveBeenCalled();
+  });
+
+  it("rejects type without ref before calling browserAct", async () => {
+    const tool = createBrowserTool();
+    await expect(
+      tool.execute?.("call-1", {
+        action: "act",
+        request: { kind: "type", text: "hello" },
+      }),
+    ).rejects.toThrow(/requires ref.*action=snapshot/i);
+    expect(browserActionsMocks.browserAct).not.toHaveBeenCalled();
+  });
+
+  it("rejects hover without ref before calling browserAct", async () => {
+    const tool = createBrowserTool();
+    await expect(
+      tool.execute?.("call-1", {
+        action: "act",
+        request: { kind: "hover" },
+      }),
+    ).rejects.toThrow(/requires ref.*action=snapshot/i);
+    expect(browserActionsMocks.browserAct).not.toHaveBeenCalled();
+  });
+
+  it("rejects press without key before calling browserAct", async () => {
+    const tool = createBrowserTool();
+    await expect(
+      tool.execute?.("call-1", {
+        action: "act",
+        request: { kind: "press" },
+      }),
+    ).rejects.toThrow(/requires key/i);
+    expect(browserActionsMocks.browserAct).not.toHaveBeenCalled();
+  });
+
+  it("rejects fill without fields before calling browserAct", async () => {
+    const tool = createBrowserTool();
+    await expect(
+      tool.execute?.("call-1", {
+        action: "act",
+        request: { kind: "fill" },
+      }),
+    ).rejects.toThrow(/requires fields/i);
+    expect(browserActionsMocks.browserAct).not.toHaveBeenCalled();
+  });
+
+  it("rejects fill with empty fields array before calling browserAct", async () => {
+    const tool = createBrowserTool();
+    await expect(
+      tool.execute?.("call-1", {
+        action: "act",
+        request: { kind: "fill", fields: [] },
+      }),
+    ).rejects.toThrow(/requires fields/i);
+    expect(browserActionsMocks.browserAct).not.toHaveBeenCalled();
